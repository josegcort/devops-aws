pipeline {
    agent any
    //Evita checkout a git automatico
    // options { skipDefaultCheckout() }

    stages {
        //Obtener codigo
        stage('Get Code') {
            agent { label 'main' }
            steps {
                //Identificacion del nodo
                sh '''
                    whoami
                    hostname
                    echo ${WORKSPACE}
                '''

                //Limpia el workspace
                deleteDir()

                //Obtener codigo fuente rama develop con token
                //set -e Hace que el pipeline falle si cualquier comando devuelve error.
                withCredentials([string(credentialsId: 'GIT_TOKEN', variable: 'TOKEN')]) {
                    sh '''
                        set -e

                        echo ${WORKSPACE}

                        git clone --branch develop https://$TOKEN@github.com/josegcort/devops-aws.git .
                    '''
                }

                //Almacena temporalmente el codigo
                stash name:'code', includes:'**'
            }
        }

        //Test de analisis de codigo estatico con Flake8 y Test de seguridad con Bandit
        stage('Static') {
            agent { label 'main' }
            steps {
                //Identificacion del nodo
                sh '''
                    whoami
                    hostname
                    echo ${WORKSPACE}
                '''

                //Recupera el codigo
                unstash 'code'

                //Asegura la continuidad del pipeline, solo se revisa el directorio src
                //set +e Hace que el pipeline no se detiene aunque un comando retorne error.
                catchError(buildResult: 'SUCCESS', stageResult: 'SUCCESS') {
                    sh '''
                        set +e

                        mkdir -p reports

                        /var/lib/jenkins/venv/bin/python3 -m flake8 --exit-zero --format=pylint src > reports/result-flake8.out

                        /var/lib/jenkins/venv/bin/python3 -m bandit --exit-zero -r src -f custom -o reports/result-bandit.out --msg-template "{abspath}:{line}: [{test_id}] {msg}"
                    '''
                    recordIssues(
                        tools: [
                            flake8(name: 'Flake8', pattern: 'reports/result-flake8.out'),
                            pyLint(name: 'Bandit', pattern: 'reports/result-bandit.out')
                        ]
                    )
                }
            }
        }

        //Deploy a staging con SAM CLI y obtencion del endpoint del servicio desplegado
        stage('Deploy') {
            agent { label 'main' }
            steps {
                //Identificacion del nodo
                sh '''
                    whoami
                    hostname
                    echo ${WORKSPACE}
                '''

                //Recupera el codigo
                unstash 'code'

                //set -e Hace que el pipeline falle si cualquier comando devuelve error.
                sh '''
                    set -e

                    sam build

                    sam deploy --config-env staging
                '''

                //set -e Hace que el pipeline falle si cualquier comando devuelve error.
                sh '''
                   aws cloudformation describe-stacks --stack-name staging-todo-list-aws --query 'Stacks[0].Outputs[?OutputKey==`BaseUrlApi`].OutputValue' --region us-east-1 --output text >> endpoint.txt
                '''

                //Almacena temporalmente el el endpont del servicio desplegado
                stash name:'endpoint', includes:'endpoint.txt'
            }
        }

        //Test del servicio REST desplegado en staging, prueba todos los endpoints
        stage('Rest Test') {
            agent { label 'nodo_aux' }
            steps {
                //Identificacion del nodo
                sh '''
                    whoami
                    hostname
                    echo ${WORKSPACE}
                '''

                //Recupera el codigo
                unstash 'code'

                //Recupera el endpoint del servicio desplegado
                unstash 'endpoint'

                //set -e Hace que el pipeline falle si cualquier comando devuelve error.
                sh '''
                    set -e

                    export BASE_URL="$(cat endpoint.txt)"

                    /home/ubuntu/venv/bin/python3 -m pytest --junitxml=reports/result-rest.xml test/integration/todoApiTest.py
                '''

                //Resultados tests del servicio REST
                junit 'reports/result-rest.xml'
            }
        }

        //Marcar la versión como “Release” y mergear a master
        stage('Promote') {
            agent { label 'main' }
            steps {
                //Identificacion del nodo
                sh '''
                    whoami
                    hostname
                    echo ${WORKSPACE}
                '''

                //Recupera el codigo
                unstash 'code'

                //Obtener codigo fuente rama develop con token
                //set -e Hace que el pipeline falle si cualquier comando devuelve error.
                withCredentials([string(credentialsId: 'GIT_TOKEN', variable: 'TOKEN')]) {
                    sh '''
                        set -e

                        echo "Configurando credenciales..."
                        git config user.name "jenkins"
                        git config user.email "jenkins@ci.local"

                        echo "Obteniendo última versión desde CHANGELOG.md..."
                        VERSION=$(sed -n "s/^## \\[\\([^]]*\\)\\].*/\\1/p" CHANGELOG.md | tail -n 1)

                        echo "Versión detectada: $VERSION"

                        echo "Cambiando a rama master..."
                        git fetch origin
                        git checkout master
                        git reset --hard origin/master

                        echo "Merge de develop → master..."
                        git merge -X ours develop --no-ff -m "Release $VERSION"

                        echo "Creando tag v$VERSION..."
                        git tag -a v$VERSION -m "Release version $VERSION"

                        echo "Push a master..."
                        git push https://$TOKEN@github.com/josegcort/devops-aws.git master

                        echo "Push del tag..."
                        git push https://$TOKEN@github.com/josegcort/devops-aws.git v$VERSION
                    '''
                }
            }
        }

        //Limpia el workspace
        stage('Clean parallel') {
            parallel {
                //Limpieza del nodo main
                stage('Clean main') {
                    agent {
                        label 'main'
                    }
                    steps {
                        //Identificacion del nodo
                        sh '''
                            whoami
                            hostname
                            echo ${WORKSPACE}
                        '''

                        deleteDir()
                    }
                }
                //Limpieza del nodo_aux
                stage('Clean nodo_aux') {
                    agent {
                        label 'nodo_aux'
                    }
                    steps {
                        //Identificacion del nodo
                        sh '''
                            whoami
                            hostname
                            echo ${WORKSPACE}
                        '''
                        deleteDir()
                    }
                }
            }
        }
    }
}
