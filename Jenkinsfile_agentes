pipeline {
    agent none
    //Evita checkout a git automatico
    // options { skipDefaultCheckout() }

    stages {
        //Obtener codigo
        stage('Get Code') {
            agent { label 'main' }
            steps {
                checkout scm
                //Identificacion del nodo
                sh '''
                    whoami
                    hostname
                    echo ${WORKSPACE}
                '''

                //Limpia el workspace
                deleteDir()

                //Obtener codigo fuente rama master con token
                //set -e Hace que el pipeline falle si cualquier comando devuelve error.
                withCredentials([string(credentialsId: 'GIT_TOKEN', variable: 'TOKEN')]) {
                    sh '''
                        set -e

                        echo ${WORKSPACE}

                        git clone --branch master https://$TOKEN@github.com/josegcort/devops-aws.git .
                    '''
                }

                //Almacena temporalmente el codigo
                stash name:'code', includes:'**'
            }
        }

        //Deploy a production con SAM CLI
        stage('Deploy') {
            agent { label 'main' }
            steps {
                //Identificacion del nodo
                sh '''
                    whoami
                    hostname
                    echo ${WORKSPACE}
                '''

                //Recupera el codigo
                unstash 'code'

                //set -e Hace que el pipeline falle si cualquier comando devuelve error.
                sh '''
                    set -e

                    sam build

                    sam deploy --config-env production
                '''

                //set -e Hace que el pipeline falle si cualquier comando devuelve error.
                sh '''
                   aws cloudformation describe-stacks --stack-name production-todo-list-aws --query 'Stacks[0].Outputs[?OutputKey==`BaseUrlApi`].OutputValue' --region us-east-1 --output text >> endpoint.txt
                '''

                //Almacena temporalmente el el endpont del servicio desplegado
                stash name:'endpoint', includes:'endpoint.txt'
            }
        }

        //Test del servicio REST desplegado en production, prueba de los endpoints de solo lectura
        stage('Rest Test') {
            agent { label 'nodo_aux' }
            steps {
                //Identificacion del nodo
                sh '''
                    whoami
                    hostname
                    echo ${WORKSPACE}
                '''

                //Recupera el codigo
                unstash 'code'

                //Recupera el endpoint del servicio desplegado
                unstash 'endpoint'

                //set -e Hace que el pipeline falle si cualquier comando devuelve error.
                sh '''
                    set -e

                    export BASE_URL="$(cat endpoint.txt)"

                    /home/ubuntu/venv/bin/python3 -m pytest --junitxml=reports/result-rest.xml test/integration/todoApiTest.py -k "test_api_listtodos or test_api_gettodo"
                '''

                //Resultados tests del servicio REST
                junit 'reports/result-rest.xml'
            }
        }

        //Limpia el workspace
        stage('Clean parallel') {
            parallel {
                //Limpieza del nodo main
                stage('Clean main') {
                    agent {
                        label 'main'
                    }
                    steps {
                        //Identificacion del nodo
                        sh '''
                            whoami
                            hostname
                            echo ${WORKSPACE}
                        '''

                        deleteDir()
                    }
                }
                //Limpieza del nodo_aux
                stage('Clean nodo_aux') {
                    agent {
                        label 'nodo_aux'
                    }
                    steps {
                        //Identificacion del nodo
                        sh '''
                            whoami
                            hostname
                            echo ${WORKSPACE}
                        '''
                        deleteDir()
                    }
                }
            }
        }
    }
}
